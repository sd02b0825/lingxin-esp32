      },
      {
        "func": "lingxin_test_voice_chat_init"
      },
      {
        "func": "lingxin_test_start_new_chat",
        "props": {
          "single_round": true,
          "task": "translate"
        }
      },
      {
        "func": "lingxin_test_stop_record"
      }
    ]
  },
